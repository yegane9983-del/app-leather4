<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/background"
    android:layoutDirection="rtl"
    android:orientation="vertical"
    android:textDirection="rtl">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:background="@drawable/bg_header_gradient"
        android:orientation="vertical"
        android:paddingStart="18dp"
        android:paddingTop="20dp"
        android:paddingEnd="18dp"
        android:paddingBottom="20dp">

        <Button
            android:id="@+id/backButton"
            style="@style/ButtonGhost"
            android:layout_width="106dp"
            android:text="→ بازگشت" />

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="17dp"
            android:text="سوابق مابه‌التفاوت"
            android:textColor="@color/text_on_primary"
            android:textSize="25sp"
            android:fontFamily="sans-serif-medium" />

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="5dp"
            android:text="گزارش ماهانه و عملکرد محصولات"
            android:textColor="#E7DBD4"
            android:textSize="14sp" />
    </LinearLayout>

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:orientation="vertical"
        android:paddingStart="16dp"
        android:paddingTop="15dp"
        android:paddingEnd="16dp"
        android:paddingBottom="14dp">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:background="@drawable/bg_card"
            android:elevation="1dp"
            android:orientation="vertical"
            android:padding="13dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:gravity="center_vertical"
                android:orientation="horizontal">

                <TextView
                    style="@style/TextSectionTitle"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="فیلتر گزارش" />

                <Button
                    android:id="@+id/clearProductFilterButton"
                    style="@style/ButtonSecondary"
                    android:layout_width="126dp"
                    android:layout_height="38dp"
                    android:minHeight="38dp"
                    android:text="پاک کردن محصول"
                    android:textSize="12sp" />
            </LinearLayout>

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="12dp"
                android:orientation="horizontal">

                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:orientation="vertical">

                    <TextView
                        style="@style/TextLabel"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="ماه" />

                    <Spinner
                        android:id="@+id/filterMonthSpinner"
                        android:layout_width="match_parent"
                        android:layout_height="48dp"
                        android:layout_marginTop="7dp"
                        android:background="@drawable/bg_input"
                        android:popupBackground="@drawable/bg_dropdown" />
                </LinearLayout>

                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="10dp"
                    android:layout_weight="1.35"
                    android:orientation="vertical">

                    <TextView
                        style="@style/TextLabel"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="محصول" />

                    <AutoCompleteTextView
                        android:id="@+id/filterProductSearchEditText"
                        style="@style/InputField"
                        android:layout_height="48dp"
                        android:layout_marginTop="7dp"
                        android:completionThreshold="0"
                        android:dropDownVerticalOffset="5dp"
                        android:hint="جستجو"
                        android:inputType="text"
                        android:popupBackground="@drawable/bg_dropdown" />
                </LinearLayout>
            </LinearLayout>
        </LinearLayout>

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="12dp"
            android:background="@drawable/bg_total_card"
            android:orientation="vertical"
            android:padding="15dp">

            <TextView
                android:id="@+id/monthlyScopeTextView"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="همه ماه‌ها • همه محصولات"
                android:textColor="@color/text_secondary"
                android:textSize="12sp"
                android:fontFamily="sans-serif-medium" />

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="8dp"
                android:gravity="center_vertical"
                android:orientation="horizontal">

                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:orientation="vertical">

                    <TextView
                        android:id="@+id/monthlyTotalTextView"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="۰ پا"
                        android:textColor="@color/text_primary"
                        android:textSize="27sp"
                        android:fontFamily="sans-serif-medium" />

                    <TextView
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="جمع مابه‌التفاوت"
                        android:textColor="@color/text_secondary"
                        android:textSize="12sp" />
                </LinearLayout>

                <LinearLayout
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:gravity="end"
                    android:orientation="vertical">

                    <TextView
                        android:id="@+id/monthlyTotalStatusTextView"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="بدون محاسبه"
                        android:textSize="12sp"
                        android:fontFamily="sans-serif-medium" />

                    <TextView
                        android:id="@+id/visibleRecordsCountTextView"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="7dp"
                        android:background="@drawable/bg_count_badge"
                        android:text="۰ رکورد"
                        android:textColor="@color/text_secondary"
                        android:textSize="11sp" />
                </LinearLayout>
            </LinearLayout>
        </LinearLayout>

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="14dp"
            android:gravity="center_vertical"
            android:orientation="horizontal">

            <TextView
                style="@style/TextSectionTitle"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="جزئیات محاسبات" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="برای حذف، نگه دارید"
                android:textColor="@color/text_secondary"
                android:textSize="11sp" />
        </LinearLayout>

        <TextView
            android:id="@+id/emptyTextView"
            android:layout_width="match_parent"
            android:layout_height="0dp"
            android:layout_weight="1"
            android:gravity="center"
            android:padding="20dp"
            android:text="برای این فیلتر، سابقه‌ای ثبت نشده است."
            android:textColor="@color/text_secondary"
            android:textSize="14sp" />

        <ListView
            android:id="@+id/recordsListView"
            android:layout_width="match_parent"
            android:layout_height="0dp"
            android:layout_marginTop="7dp"
            android:layout_weight="1"
            android:clipToPadding="false"
            android:divider="@android:color/transparent"
            android:dividerHeight="0dp"
            android:listSelector="@android:color/transparent"
            android:paddingTop="2dp"
            android:paddingBottom="4dp" />

        <Button
            android:id="@+id/clearRecordsButton"
            style="@style/ButtonDanger"
            android:layout_width="match_parent"
            android:layout_marginTop="10dp"
            android:text="حذف همه سوابق" />
    </LinearLayout>
</LinearLayout>
