<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/background"
    android:clipToPadding="false"
    android:fillViewport="true"
    android:layoutDirection="rtl"
    android:textDirection="rtl">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:paddingBottom="26dp">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:background="@drawable/bg_header_gradient"
            android:orientation="vertical"
            android:paddingStart="22dp"
            android:paddingTop="26dp"
            android:paddingEnd="22dp"
            android:paddingBottom="23dp">

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="مدیریت هوشمند مصرف"
                android:textColor="#D9C8BD"
                android:textSize="13sp"
                android:fontFamily="sans-serif-medium" />

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="6dp"
                android:text="محاسبه‌گر چرم"
                android:textColor="@color/text_on_primary"
                android:textSize="29sp"
                android:fontFamily="sans-serif-medium" />

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="7dp"
                android:lineSpacingExtra="3dp"
                android:text="مصرف واقعی را با استاندارد مقایسه کنید و کیفیت برش را ماه‌به‌ماه پایش کنید."
                android:textColor="#E7DBD4"
                android:textSize="14sp" />

            <Button
                android:id="@+id/recordsButton"
                style="@style/ButtonGhost"
                android:layout_width="match_parent"
                android:layout_marginTop="18dp"
                android:text="مشاهده سوابق ماهانه  ←" />
        </LinearLayout>

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginStart="16dp"
            android:layout_marginTop="18dp"
            android:layout_marginEnd="16dp"
            android:background="@drawable/bg_card"
            android:elevation="1dp"
            android:orientation="vertical"
            android:padding="17dp">

            <TextView
                style="@style/TextSectionTitle"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="محصولات" />

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="5dp"
                android:text="محصول و مصرف استاندارد هر عدد را تعریف کنید."
                android:textColor="@color/text_secondary"
                android:textSize="13sp" />

            <TextView
                style="@style/TextLabel"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="17dp"
                android:text="نام محصول" />

            <EditText
                android:id="@+id/productNameEditText"
                style="@style/InputField"
                android:layout_marginTop="7dp"
                android:hint="مثال: کیف اداری"
                android:inputType="text" />

            <TextView
                style="@style/TextLabel"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="13dp"
                android:text="مصرف استاندارد هر عدد (پا)" />

            <EditText
                android:id="@+id/defaultUsageEditText"
                style="@style/InputField"
                android:layout_marginTop="7dp"
                android:hint="مثال: ۴.۵"
                android:inputType="numberDecimal" />

            <Button
                android:id="@+id/addProductButton"
                style="@style/ButtonSecondary"
                android:layout_width="match_parent"
                android:layout_marginTop="16dp"
                android:text="افزودن محصول" />

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="21dp"
                android:gravity="center_vertical"
                android:orientation="horizontal">

                <TextView
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="محصولات ثبت‌شده"
                    android:textColor="@color/text_primary"
                    android:textSize="15sp"
                    android:fontFamily="sans-serif-medium" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:background="@drawable/bg_count_badge"
                    android:text="برای حذف، نگه دارید"
                    android:textColor="@color/text_secondary"
                    android:textSize="11sp" />
            </LinearLayout>

            <ListView
                android:id="@+id/productsListView"
                android:layout_width="match_parent"
                android:layout_height="196dp"
                android:layout_marginTop="9dp"
                android:clipToPadding="false"
                android:divider="@android:color/transparent"
                android:dividerHeight="0dp"
                android:listSelector="@android:color/transparent"
                android:paddingTop="2dp"
                android:paddingBottom="2dp" />
        </LinearLayout>

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginStart="16dp"
            android:layout_marginTop="14dp"
            android:layout_marginEnd="16dp"
            android:background="@drawable/bg_card"
            android:elevation="1dp"
            android:orientation="vertical"
            android:padding="17dp">

            <TextView
                style="@style/TextSectionTitle"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="محاسبه مابه‌التفاوت" />

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="5dp"
                android:text="اطلاعات تولید را وارد کنید؛ نتیجه در سوابق ذخیره می‌شود."
                android:textColor="@color/text_secondary"
                android:textSize="13sp" />

            <TextView
                style="@style/TextLabel"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="17dp"
                android:text="ماه محاسبه" />

            <Spinner
                android:id="@+id/monthSpinner"
                android:layout_width="match_parent"
                android:layout_height="52dp"
                android:layout_marginTop="7dp"
                android:background="@drawable/bg_input"
                android:popupBackground="@drawable/bg_dropdown" />

            <TextView
                style="@style/TextLabel"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="13dp"
                android:text="محصول" />

            <AutoCompleteTextView
                android:id="@+id/productSearchEditText"
                style="@style/InputField"
                android:layout_marginTop="7dp"
                android:completionThreshold="1"
                android:dropDownVerticalOffset="5dp"
                android:hint="نام محصول را جستجو کنید"
                android:inputType="text"
                android:popupBackground="@drawable/bg_dropdown" />

            <TextView
                style="@style/TextLabel"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="13dp"
                android:text="تعداد تولید" />

            <EditText
                android:id="@+id/quantityEditText"
                style="@style/InputField"
                android:layout_marginTop="7dp"
                android:hint="تعداد محصول"
                android:inputType="numberDecimal" />

            <TextView
                style="@style/TextLabel"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="13dp"
                android:text="چرم مصرفی واقعی (پا)" />

            <EditText
                android:id="@+id/actualLeatherEditText"
                style="@style/InputField"
                android:layout_marginTop="7dp"
                android:hint="مقدار واقعی مصرف چرم"
                android:inputType="numberDecimal" />

            <Button
                android:id="@+id/calculateButton"
                style="@style/ButtonPrimary"
                android:layout_width="match_parent"
                android:layout_marginTop="19dp"
                android:text="محاسبه و ثبت نتیجه" />
        </LinearLayout>

        <LinearLayout
            android:id="@+id/resultCard"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginStart="16dp"
            android:layout_marginTop="14dp"
            android:layout_marginEnd="16dp"
            android:background="@drawable/bg_card"
            android:elevation="1dp"
            android:orientation="vertical"
            android:padding="17dp"
            android:visibility="gone">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:gravity="center_vertical"
                android:orientation="horizontal">

                <TextView
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="نتیجه محاسبه"
                    android:textColor="@color/text_primary"
                    android:textSize="17sp"
                    android:fontFamily="sans-serif-medium" />

                <TextView
                    android:id="@+id/resultStatusTextView"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="برش خوب"
                    android:textSize="13sp"
                    android:fontFamily="sans-serif-medium" />
            </LinearLayout>

            <TextView
                android:id="@+id/resultDifferenceTextView"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="14dp"
                android:text="−۰ پا"
                android:textColor="@color/text_primary"
                android:textSize="27sp"
                android:fontFamily="sans-serif-medium" />

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="مابه‌التفاوت مصرف واقعی با استاندارد"
                android:textColor="@color/text_secondary"
                android:textSize="12sp" />

            <TextView
                android:id="@+id/resultTextView"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="15dp"
                android:background="@drawable/bg_input"
                android:lineSpacingExtra="5dp"
                android:padding="13dp"
                android:textColor="@color/text_secondary"
                android:textSize="14sp" />
        </LinearLayout>
    </LinearLayout>
</ScrollView>
